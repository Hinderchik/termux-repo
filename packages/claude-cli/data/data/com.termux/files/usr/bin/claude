#!/data/data/com.termux/files/usr/bin/bash

CONFIG_DIR="$HOME/.config/claude-cli"
CONFIG_FILE="$CONFIG_DIR/config.sh"

# Проверяем, есть ли конфиг
if [ ! -f "$CONFIG_FILE" ]; then
    echo "════════════════════════════════════════════════════════════╗"
    echo "║     Claude Code CLI — Первоначальная настройка           ║"
    echo "╚════════════════════════════════════════════════════════════╝"
    echo ""
    
    mkdir -p "$CONFIG_DIR"
    
    echo "➜ Введите ANTHROPIC_API_KEY:"
    read ANTHROPIC_API_KEY
    echo "➜ Введите ANTHROPIC_BASE_URL (Enter = https://api.anthropic.com):"
    read ANTHROPIC_BASE_URL
    ANTHROPIC_BASE_URL=${ANTHROPIC_BASE_URL:-https://api.anthropic.com}
    echo "➜ Введите модель (Enter = claude-opus-4-6-20250514):"
    read ANTHROPIC_MODEL
    ANTHROPIC_MODEL=${ANTHROPIC_MODEL:-claude-opus-4-6-20250514}
    
    cat > "$CONFIG_FILE" << EOF
export ANTHROPIC_API_KEY='$ANTHROPIC_API_KEY'
export ANTHROPIC_BASE_URL='$ANTHROPIC_BASE_URL'
export ANTHROPIC_MODEL='$ANTHROPIC_MODEL'
EOF
    
    echo "✅ Настройка сохранена в $CONFIG_FILE"
    echo ""
fi

# Загружаем конфиг
source "$CONFIG_FILE"

# Текущая папка или аргумент
TARGET_DIR="${1:-$(pwd)}"
if [ ! -d "$TARGET_DIR" ]; then
    mkdir -p "$TARGET_DIR"
fi

echo "🚀 Запуск Claude в $TARGET_DIR"

# Запускаем Claude Code CLI внутри Alpine
# Проверяем, установлен ли Claude Code CLI
proot-distro login alpine -- bash -c "
    if ! command -v claude &> /dev/null; then
        echo '📦 Установка Claude Code CLI...'
        npm install -g @anthropic-ai/claude-code
    fi
    cd '$TARGET_DIR'
    export ANTHROPIC_API_KEY='$ANTHROPIC_API_KEY'
    export ANTHROPIC_BASE_URL='$ANTHROPIC_BASE_URL'
    export ANTHROPIC_MODEL='$ANTHROPIC_MODEL'
    claude
"
